{
  "version": 2,
  "installCommand": "pnpm install",
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "artifacts/poem-app/dist/public" }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/status", "dest": "/api/index.js" },
    { "src": "/api/healthz", "dest": "/api/index.js" },
    { "src": "/api/translate", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
