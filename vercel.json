{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/poem-app run build",
  "outputDirectory": "artifacts/poem-app/dist/public",
  "framework": null,
  "functions": {
    "api/translate.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
